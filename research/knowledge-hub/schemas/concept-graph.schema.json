{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/concept-graph.schema.json",
  "title": "SourceConceptGraph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "graph_version",
    "topic_slug",
    "source_id",
    "source_json_path",
    "generated_at",
    "generated_by",
    "provider",
    "nodes",
    "edges",
    "hyperedges",
    "communities",
    "god_nodes"
  ],
  "properties": {
    "kind": { "const": "source_concept_graph" },
    "graph_version": { "type": "integer", "const": 1 },
    "topic_slug": { "type": "string", "minLength": 1 },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
    },
    "source_json_path": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
    "hyperedges": { "type": "array", "items": { "$ref": "#/$defs/hyperedge" } },
    "communities": { "type": "array", "items": { "$ref": "#/$defs/community" } },
    "god_nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "label",
        "node_type",
        "confidence_tier",
        "confidence_score",
        "evidence_refs",
        "notes"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "node_type": {
          "type": "string",
          "enum": [
            "concept",
            "method",
            "finding",
            "theorem",
            "definition",
            "conjecture",
            "regime",
            "approximation",
            "notation_system",
            "proof",
            "equation",
            "observable"
          ]
        },
        "confidence_tier": {
          "type": "string",
          "enum": ["EXTRACTED", "INFERRED", "AMBIGUOUS"]
        },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "from_id", "relation", "to_id", "evidence_refs", "notes"],
      "properties": {
        "edge_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "from_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
        },
        "relation": {
          "type": "string",
          "enum": [
            "depends_on",
            "related_to",
            "assumes",
            "valid_in",
            "contradicts",
            "derives",
            "notation_for",
            "generalizes",
            "special_case_of",
            "implies"
          ]
        },
        "to_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      }
    },
    "hyperedge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hyperedge_id", "relation", "node_ids", "evidence_refs", "notes"],
      "properties": {
        "hyperedge_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "relation": { "type": "string", "minLength": 1 },
        "node_ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      }
    },
    "community": {
      "type": "object",
      "additionalProperties": false,
      "required": ["community_id", "label", "node_ids"],
      "properties": {
        "community_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "node_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
          }
        }
      }
    }
  }
}
