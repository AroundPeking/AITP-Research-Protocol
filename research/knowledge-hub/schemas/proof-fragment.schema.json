{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/proof-fragment.schema.json",
  "title": "ProofFragmentPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal",
    "construction_steps",
    "common_pitfalls",
    "reuse_conditions",
    "do_not_apply_when"
  ],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "construction_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "common_pitfalls": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reuse_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "do_not_apply_when": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supporting_lemmas": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_signatures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result_shape": {
      "type": "string",
      "minLength": 1
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "observed_in_run",
        "locally_validated",
        "remotely_validated",
        "promoted"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
