{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/exploration-window.schema.json",
  "title": "ExplorationWindowCarrier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "window_version",
    "time_window",
    "active_scope",
    "constraints"
  ],
  "properties": {
    "window_version": {
      "type": "integer",
      "const": 1
    },
    "time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opened_at",
        "closes_at"
      ],
      "properties": {
        "opened_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "closes_at": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "active_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic_slug",
        "question"
      ],
      "properties": {
        "topic_slug": {
          "type": [
            "string",
            "null"
          ]
        },
        "question": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocked_layers",
        "notes"
      ],
      "properties": {
        "blocked_layers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
