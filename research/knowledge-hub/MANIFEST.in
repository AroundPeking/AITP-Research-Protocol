include README.md
include requirements.txt
include *.md
include *.json
recursive-include canonical *
recursive-include consultation *
recursive-include feedback *
recursive-include intake *
recursive-include runtime *
recursive-include schemas *
recursive-include source-layer *
recursive-include validation *
exclude runtime/current_topic.json
exclude runtime/current_topic.md
exclude runtime/topic_index.jsonl
prune runtime/topics
prune source-layer/topics
prune intake/topics
prune feedback/topics
prune validation/topics
prune consultation/topics
global-exclude __pycache__
global-exclude *.py[cod]
