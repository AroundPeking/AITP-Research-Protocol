{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/deferred-candidate-buffer.schema.json",
  "title": "DeferredCandidateBuffer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "buffer_version",
    "topic_slug",
    "entries",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "buffer_version": {
      "type": "integer",
      "const": 1
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "source_candidate_id",
          "title",
          "summary",
          "reason",
          "status"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "pattern": "^deferred:[a-z0-9][a-z0-9-]*$"
          },
          "source_candidate_id": {
            "type": "string",
            "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "buffered",
              "reactivated",
              "dismissed"
            ]
          },
          "required_l2_types": {
            "type": "array",
            "items": {
              "$ref": "https://aitp.local/schemas/candidate.schema.json#/properties/candidate_type"
            }
          },
          "reactivation_conditions": {
            "type": "object"
          },
          "reactivation_candidate": {
            "type": "object"
          },
          "activated_candidate_id": {
            "type": "string",
            "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
          },
          "activated_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
