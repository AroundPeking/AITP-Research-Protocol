{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.dev/runtime/schemas/runtime-live-first-turn-evidence.schema.json",
  "title": "AITP Runtime Live First-Turn Evidence",
  "description": "Manual-but-machine-checkable evidence captured from a real first substantive agent turn after front-door bootstrap.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_kind",
    "contract_version",
    "runtime",
    "status",
    "captured_at",
    "entry_surface",
    "operator_summary",
    "checks",
    "artifacts"
  ],
  "properties": {
    "report_kind": {
      "const": "runtime_live_first_turn_evidence"
    },
    "contract_version": {
      "const": 1
    },
    "runtime": {
      "type": "string",
      "enum": [
        "codex",
        "claude_code",
        "opencode"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "verified",
        "partial",
        "failed"
      ]
    },
    "captured_at": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute timestamp or stable run stamp for the captured live-app turn."
    },
    "entry_surface": {
      "type": "string",
      "minLength": 1
    },
    "operator_summary": {
      "type": "string",
      "minLength": 1
    },
    "first_user_turn": {
      "type": "string"
    },
    "first_agent_turn_summary": {
      "type": "string"
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bootstrap_consumed_before_first_substantive_action",
        "human_interaction_posture_visible",
        "autonomy_posture_visible",
        "wait_state_matches_contract",
        "continue_state_matches_contract"
      ],
      "properties": {
        "bootstrap_consumed_before_first_substantive_action": {
          "type": "boolean"
        },
        "human_interaction_posture_visible": {
          "type": "boolean"
        },
        "autonomy_posture_visible": {
          "type": "boolean"
        },
        "wait_state_matches_contract": {
          "type": "boolean"
        },
        "continue_state_matches_contract": {
          "type": "boolean"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transcript_path",
        "session_start_path",
        "runtime_protocol_path",
        "status_payload_path",
        "evidence_refs"
      ],
      "properties": {
        "transcript_path": {
          "type": "string",
          "minLength": 1
        },
        "session_start_path": {
          "type": "string",
          "minLength": 1
        },
        "runtime_protocol_path": {
          "type": "string",
          "minLength": 1
        },
        "status_payload_path": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
