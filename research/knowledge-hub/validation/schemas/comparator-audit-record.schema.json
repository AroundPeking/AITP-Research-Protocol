{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/comparator-audit-record.schema.json",
  "title": "ComparatorAuditRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic_slug",
    "run_id",
    "candidate_id",
    "candidate_type",
    "formal_theory_role",
    "status",
    "goal",
    "nearby_variants",
    "risks",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "topic_slug": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "candidate_type": {
      "type": "string"
    },
    "formal_theory_role": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "nearby_variants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/variant"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    }
  },
  "$defs": {
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "relation",
        "verdict",
        "notes"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "relation": {
          "type": "string"
        },
        "verdict": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
