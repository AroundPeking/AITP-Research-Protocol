{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/formal-theory-review.schema.json",
  "title": "FormalTheoryReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic_slug",
    "run_id",
    "candidate_id",
    "candidate_type",
    "formal_theory_role",
    "statement_graph_role",
    "target_statement_id",
    "faithfulness_status",
    "comparator_audit_status",
    "provenance_kind",
    "prerequisite_closure_status",
    "overall_status",
    "blocking_reasons",
    "faithfulness_review_path",
    "comparator_audit_record_path",
    "provenance_review_path",
    "prerequisite_closure_review_path",
    "formal_theory_review_path",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "topic_slug": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "candidate_type": {
      "type": "string"
    },
    "formal_theory_role": {
      "type": "string"
    },
    "statement_graph_role": {
      "type": "string"
    },
    "definition_trust_tier": {
      "type": "string"
    },
    "target_statement_id": {
      "type": "string"
    },
    "statement_graph_parents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "statement_graph_children": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "faithfulness_status": {
      "type": "string"
    },
    "faithfulness_strategy": {
      "type": "string"
    },
    "faithfulness_notes": {
      "type": "string"
    },
    "informal_statement": {
      "type": "string"
    },
    "formal_target": {
      "type": "string"
    },
    "comparator_audit_status": {
      "type": "string"
    },
    "comparator_goal": {
      "type": "string"
    },
    "comparator_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nearby_variants": {
      "type": "array",
      "items": {
        "$ref": "comparator-audit-record.schema.json#/$defs/variant"
      }
    },
    "comparator_notes": {
      "type": "string"
    },
    "provenance_kind": {
      "type": "string"
    },
    "attribution_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_notes": {
      "type": "string"
    },
    "prerequisite_closure_status": {
      "type": "string"
    },
    "lean_prerequisite_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supporting_obligation_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formalization_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prerequisite_notes": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "faithfulness_review_path": {
      "type": "string"
    },
    "comparator_audit_record_path": {
      "type": "string"
    },
    "provenance_review_path": {
      "type": "string"
    },
    "prerequisite_closure_review_path": {
      "type": "string"
    },
    "formal_theory_review_path": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    }
  }
}
