{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/provenance-review.schema.json",
  "title": "ProvenanceReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic_slug",
    "run_id",
    "candidate_id",
    "candidate_type",
    "provenance_kind",
    "attribution_requirements",
    "provenance_sources",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "topic_slug": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "candidate_type": {
      "type": "string"
    },
    "provenance_kind": {
      "type": "string"
    },
    "attribution_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    }
  }
}
