{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/prerequisite-closure-review.schema.json",
  "title": "PrerequisiteClosureReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic_slug",
    "run_id",
    "candidate_id",
    "candidate_type",
    "formal_theory_role",
    "status",
    "lean_prerequisite_ids",
    "supporting_obligation_ids",
    "formalization_blockers",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "topic_slug": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "candidate_type": {
      "type": "string"
    },
    "formal_theory_role": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "lean_prerequisite_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supporting_obligation_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formalization_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    }
  }
}
