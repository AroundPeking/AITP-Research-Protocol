{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/promotion-decision.schema.json",
  "title": "L4PromotionDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "candidate_id",
    "route",
    "verdict",
    "promoted_units",
    "fallback_targets",
    "evidence_refs",
    "decided_by",
    "decided_at",
    "reason"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^decision:[a-z0-9][a-z0-9-]*$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "route": {
      "type": "string",
      "enum": [
        "L3->L4->L2",
        "L1->L2",
        "L1->L2_auto",
        "L3->L4_auto->L2_auto",
        "L2_auto->L2"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "accepted",
        "deferred",
        "rejected",
        "needs_revision"
      ]
    },
    "promoted_units": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "fallback_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decided_by": {
      "type": "string"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_mode": {
      "type": "string",
      "enum": [
        "human",
        "ai_auto",
        "hybrid"
      ]
    },
    "canonical_layer": {
      "type": "string",
      "enum": [
        "L2",
        "L2_auto"
      ]
    },
    "coverage_status": {
      "type": "string"
    },
    "consensus_status": {
      "type": "string"
    },
    "merge_outcome": {
      "type": "string"
    },
    "merge_target_unit": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
