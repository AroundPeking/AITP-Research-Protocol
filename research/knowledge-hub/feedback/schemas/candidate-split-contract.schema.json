{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/candidate-split-contract.schema.json",
  "title": "CandidateSplitContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "splits"
  ],
  "properties": {
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "policy_note": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    },
    "splits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_candidate_id",
          "reason",
          "child_candidates",
          "deferred_fragments"
        ],
        "properties": {
          "source_candidate_id": {
            "type": "string",
            "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "retire_source_candidate": {
            "type": "boolean"
          },
          "child_candidates": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/split_candidate"
            }
          },
          "deferred_fragments": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/deferred_fragment"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "split_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "candidate_type",
        "title",
        "summary",
        "origin_refs",
        "question",
        "assumptions",
        "proposed_validation_route",
        "intended_l2_targets"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
        },
        "candidate_type": {
          "$ref": "https://aitp.local/schemas/candidate.schema.json#/properties/candidate_type"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "origin_refs": {
          "type": "array",
          "items": {
            "$ref": "https://aitp.local/schemas/object-ref.schema.json"
          }
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "proposed_validation_route": {
          "type": "string",
          "minLength": 1
        },
        "intended_l2_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_validation",
            "returned_to_l3",
            "reactivated"
          ]
        }
      }
    },
    "deferred_fragment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "title",
        "summary",
        "reason"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "pattern": "^deferred:[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "required_l2_types": {
          "type": "array",
          "items": {
            "$ref": "https://aitp.local/schemas/candidate.schema.json#/properties/candidate_type"
          }
        },
        "reactivation_conditions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_ids_any": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "text_contains_any": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "child_topics_any": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "reactivation_candidate": {
          "$ref": "#/$defs/split_candidate"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
