{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CalculationDebugContract",
  "description": "Records the diagnosis and fix of a failed first-principles calculation, capturing root cause and learned knowledge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "debug_id",
    "original_workflow_id",
    "failure_stage",
    "error_classification",
    "fix_actions",
    "verification"
  ],
  "properties": {
    "debug_id": { "type": "string", "minLength": 1 },
    "original_workflow_id": { "type": "string", "minLength": 1 },
    "failure_stage": { "type": "string", "enum": ["scf", "df", "nscf", "librpa", "postprocess"] },
    "error_classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "root_cause"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "convergence_failure",
            "input_mismatch",
            "resource_exhaustion",
            "numerical_instability",
            "basis_incompatibility",
            "toolchain_error",
            "unknown"
          ]
        },
        "root_cause": { "type": "string", "minLength": 1 },
        "error_log_excerpt": { "type": "string" }
      }
    },
    "fix_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "target", "details"],
        "properties": {
          "action": { "type": "string", "enum": ["parameter_change", "input_correction", "resource_adjustment", "code_patch", "workflow_restart"] },
          "target": { "type": "string", "minLength": 1 },
          "details": { "type": "string", "minLength": 1 }
        }
      },
      "minItems": 1
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["re_run_status"],
      "properties": {
        "re_run_status": { "type": "string", "enum": ["passed", "failed", "not_yet_run"] },
        "smoke_test_passed": { "type": "boolean" },
        "deviation_from_expected": { "type": "string" }
      }
    },
    "learned_knowledge": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string" },
        "applicable_contexts": { "type": "array", "items": { "type": "string" } },
        "avoid_patterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "topic_slug": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  }
}
