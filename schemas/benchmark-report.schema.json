{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BenchmarkReportContract",
  "description": "Reports the results of benchmarking a first-principles feature or calculation against known reference values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "feature",
    "target_version",
    "baseline_version",
    "test_systems",
    "verdict",
    "ready_for_production"
  ],
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "feature": { "type": "string", "minLength": 1 },
    "target_version": { "type": "string", "minLength": 1 },
    "baseline_version": { "type": "string", "minLength": 1 },
    "test_systems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "system_type", "results"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "system_type": { "type": "string", "enum": ["molecule", "solid", "2D"] },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["observable", "new_value", "baseline_value", "deviation", "pass"],
              "properties": {
                "observable": { "type": "string", "minLength": 1 },
                "new_value": { "type": "number" },
                "baseline_value": { "type": "number" },
                "deviation": { "type": "string", "minLength": 1 },
                "pass": { "type": "boolean" },
                "tolerance": { "type": "string" }
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    },
    "convergence_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parameter", "values", "observed_convergence"],
        "properties": {
          "parameter": { "type": "string", "minLength": 1 },
          "values": { "type": "array", "items": { "type": "number" } },
          "observed_convergence": { "type": "string", "enum": ["monotonic", "oscillating", "non_convergent", "insufficient_data"] }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "partial", "fail", "blocked"] },
    "ready_for_production": { "type": "boolean" },
    "topic_slug": { "type": "string", "minLength": 1 },
    "related_task_id": { "type": "string" },
    "notes": { "type": "string" }
  }
}
