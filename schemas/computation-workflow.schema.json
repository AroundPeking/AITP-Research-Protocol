{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComputationWorkflowContract",
  "description": "Defines a first-principles physics computation workflow (GW or RPA) with ABACUS and LibRPA.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "computation_type",
    "system_type",
    "structure_file",
    "stages",
    "basis_integrity",
    "compute"
  ],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "computation_type": { "type": "string", "enum": ["gw", "rpa"] },
    "system_type": { "type": "string", "enum": ["molecule", "solid", "2D"] },
    "structure_file": { "type": "string", "minLength": 1 },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "input_files", "output_artifacts"],
        "properties": {
          "name": { "type": "string", "enum": ["scf", "df", "nscf", "librpa", "postprocess"] },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "skipped"] },
          "input_files": { "type": "array", "items": { "type": "string" } },
          "output_artifacts": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "basis_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pseudopotentials", "nao_orbitals"],
      "properties": {
        "pseudopotentials": { "type": "array", "items": { "type": "string" } },
        "nao_orbitals": { "type": "array", "items": { "type": "string" } },
        "abfs_orbitals": { "type": "array", "items": { "type": "string" } },
        "shrink_invariant": { "type": "boolean", "description": "True if ABFS_ORBITAL presence matches use_shrink_abfs in librpa.in" }
      }
    },
    "compute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["location"],
      "properties": {
        "location": { "type": "string", "enum": ["local", "server"] },
        "server_alias": { "type": "string" },
        "host": { "type": "string" },
        "mpi_np": { "type": "integer", "minimum": 1 },
        "cpus_per_task": { "type": "integer", "minimum": 1 },
        "omp_num_threads": { "type": "integer", "minimum": 1 }
      }
    },
    "topic_slug": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  }
}
