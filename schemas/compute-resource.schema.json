{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComputeResourceContract",
  "description": "Defines a compute resource (local or remote server) for first-principles calculations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resource_id",
    "location"
  ],
  "properties": {
    "resource_id": { "type": "string", "minLength": 1 },
    "location": { "type": "string", "enum": ["local", "server"] },
    "alias": { "type": "string", "description": "Human-readable alias matching SSH config" },
    "host": { "type": "string" },
    "description": { "type": "string" },
    "environment": { "type": "string", "enum": ["production", "staging", "test", "development"] },
    "modules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Environment modules to load (e.g. oneapi, intelmpi)"
    },
    "abacus_path": { "type": "string", "description": "Path to ABACUS executable" },
    "librpa_path": { "type": "string", "description": "Path to LibRPA executable or library" },
    "libri_path": { "type": "string", "description": "Path to LibRI (must be same version as linked by ABACUS and LibRPA)" },
    "slurm_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partition": { "type": "string" },
        "cpus_per_task": { "type": "integer", "minimum": 1 },
        "omp_num_threads": { "type": "integer", "minimum": 1 },
        "mem_per_cpu": { "type": "string" },
        "time_limit": { "type": "string" }
      }
    },
    "conda_env": { "type": "string", "description": "Default conda environment for pyatb and other Python tools" },
    "scratch_dir": { "type": "string", "description": "Fast storage path for I/O-heavy calculations" }
  }
}
