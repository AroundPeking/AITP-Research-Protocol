{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aitp.dev/schemas/topic-skill-projection.schema.json",
  "title": "TopicSkillProjection",
  "description": "Runtime-derived reusable execution projection for a mature topic. In the formal_theory lane this is reusable execution memory, not a theorem certificate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "topic_slug",
    "source_topic_slug",
    "run_id",
    "title",
    "summary",
    "lane",
    "status",
    "status_reason",
    "entry_signals",
    "required_first_reads",
    "required_first_routes",
    "benchmark_first_rules",
    "operator_checkpoint_rules",
    "operation_trust_requirements",
    "strategy_guidance",
    "forbidden_proxies",
    "derived_from_artifacts",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^topic_skill_projection:[a-z0-9][a-z0-9-]*$"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "source_topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "description": "The topic lane this projection is derived from. formal_theory projections remain theorem-facing execution memory rather than theorem truth claims.",
      "enum": [
        "formal_theory",
        "toy_numeric",
        "code_method"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "blocked",
        "not_applicable"
      ]
    },
    "status_reason": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable explanation for why the projection is available, blocked, or not applicable. For formal_theory this should name the gating trust artifacts."
    },
    "candidate_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "intended_l2_target": {
      "type": [
        "string",
        "null"
      ]
    },
    "entry_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_first_reads": {
      "type": "array",
      "description": "Files the next agent should read before reusing the route. For formal_theory this should include theorem-facing trust artifacts before any theorem-level reuse claim.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_first_routes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "benchmark_first_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operator_checkpoint_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operation_trust_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategy_guidance": {
      "type": "array",
      "description": "Reusable route guidance distilled from strategy memory. Guidance may steer execution, but does not by itself certify theorem truth or proof closure.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_proxies": {
      "type": "array",
      "description": "Reusable anti-proxy rules. For formal_theory this should forbid treating the projection itself as theorem certification or proof-complete evidence.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "derived_from_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    }
  }
}
