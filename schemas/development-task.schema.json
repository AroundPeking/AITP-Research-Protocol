{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevelopmentTaskContract",
  "description": "Defines a software development task for ABACUS, LibRPA, LibRI, or related first-principles toolchain components.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "target",
    "feature_description",
    "motivation",
    "code_location",
    "build_config",
    "validation"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "enum": ["abacus", "librpa", "libri", "libcomm", "pyatb", "other"] },
    "feature_description": { "type": "string", "minLength": 1 },
    "motivation": { "type": "string", "minLength": 1 },
    "code_location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "branch"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "key_files": { "type": "array", "items": { "type": "string" } },
        "depends_on": { "type": "array", "items": { "type": "string" } }
      }
    },
    "build_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolchain"],
      "properties": {
        "cmake_profile": { "type": "string" },
        "toolchain": { "type": "string", "enum": ["gnu", "intel", "intel-oneapi"] },
        "dependency_paths": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Map of dependency name to install prefix (e.g. {\"ELPA\": \"/opt/elpa\", \"LibXC\": \"/opt/libxc\"})"
        },
        "cmake_flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["physical_correctness"],
      "properties": {
        "unit_tests": { "type": "array", "items": { "type": "string" } },
        "integration_tests": { "type": "array", "items": { "type": "string" } },
        "physical_correctness": { "type": "string", "minLength": 1, "description": "How to verify the feature produces physically meaningful results" },
        "regression_against": { "type": "string", "description": "Baseline version or commit to compare against" }
      }
    },
    "topic_slug": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["planned", "in_progress", "review", "merged", "blocked"] },
    "related_computation": { "type": "string", "description": "workflow_id of a computation that motivated or will validate this feature" },
    "notes": { "type": "string" }
  }
}
