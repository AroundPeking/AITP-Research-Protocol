{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{CLAUDE_USER_DIR}}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"{{CLAUDE_USER_DIR}}/hooks/aitp-keyword-router.py\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"{{CLAUDE_USER_DIR}}/hooks/aitp-routing-guard.py\"",
            "async": false
          }
        ]
      }
    ]
  }
}
